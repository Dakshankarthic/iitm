# DriveLegal — Environment Variables
# Copy this file to .env and fill in your values

# ── Ollama / OpenAI-Compatible (Primary AI) ──────────────────────────────────
# To use a Cloud API (like DeepSeek), change these values:
# OLLAMA_BASE_URL=https://api.deepseek.com
# OLLAMA_API_KEY=your_deepseek_api_key_here
# OLLAMA_MODEL=deepseek-chat
#
# For Local PC Ollama, leave as is:
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_API_KEY=ollama
OLLAMA_MODEL=gemma4:31b-cloud
OLLAMA_VISION_MODEL=llama3.2-vision:latest

# ── Gemini API Key (Cloud AI — Fallback) ─────────────────────────────────────
# Get a free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── To Force Cloud AI Only (Disable Local Ollama) ────────────────────────────
# Set this to true if your PC cannot run local AI models
DISABLE_OLLAMA=false

# ── Optional: override backend port ──────────────────────────────────────────
# PORT=8000
